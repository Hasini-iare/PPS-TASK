def detect_trend(prices):
    increase = 0
    decrease = 0

    for i in range(1, len(prices)):
        if prices[i] > prices[i - 1]:
            increase += 1
        elif prices[i] < prices[i - 1]:
            decrease += 1

    if increase > decrease:
        return "Upward"
    elif decrease > increase:
        return "Downward"
    else:
        return "Stable"


def get_advisory(trend):
    if trend == "Upward":
        return "Wait"
    elif trend == "Downward":
        return "Sell Now"
    else:
        return "Hold"


# Input
n = int(input())
prices = list(map(int, input().split()))

# Trend analysis
trend = detect_trend(prices)
advisory = get_advisory(trend)

# Output
print(advisory)
